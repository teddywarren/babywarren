<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Baby Warren</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400;1,500&family=Jost:wght@200;300;400&display=swap" rel="stylesheet">
<style>
  :root {
    --ivory: #f7f4ef;
    --ivory-dark: #ede9e0;
    --ivory-deep: #ddd8cc;
    --ink: #2a2620;
    --ink-light: #6b6458;
    --ink-lighter: #a09890;
    --oak: #8b7355;
    --oak-light: #c4ad8f;
    --white: #fdfcfa;
    --serif: 'Playfair Display', Georgia, serif;
    --sans: 'Jost', sans-serif;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--sans);
    background: var(--ivory);
    color: var(--ink);
    font-weight: 300;
    line-height: 1.6;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
  }

  /* ── PAGES ── */
  .page { display: none; }
  .page.active { display: block; animation: reveal .5s ease both; }
  @keyframes reveal {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── NAV ── */
  nav {
    position: sticky; top: 0; z-index: 200;
    background: var(--ivory);
    border-bottom: 1px solid var(--ivory-deep);
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.4rem 3rem;
  }
  .nav-wordmark {
    font-family: var(--serif);
    font-size: 1.05rem;
    font-weight: 400;
    letter-spacing: .08em;
    color: var(--ink);
    cursor: pointer;
    user-select: none;
  }
  .nav-wordmark span { font-style: normal; color: var(--ink); }
  .nav-links { display: flex; gap: 2.5rem; align-items: center; }
  .nav-btn {
    font-family: var(--sans);
    font-size: .65rem;
    font-weight: 400;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--ink-lighter);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: color .25s;
    position: relative;
  }
  .nav-btn::after {
    content: '';
    position: absolute;
    bottom: -3px; left: 0; right: 0;
    height: 1px;
    background: var(--oak);
    transform: scaleX(0);
    transition: transform .25s;
  }
  .nav-btn:hover { color: var(--ink); }
  .nav-btn:hover::after, .nav-btn.active::after { transform: scaleX(1); }
  .nav-btn.active { color: var(--ink); }
  .nav-lock {
    display: inline-flex;
    align-items: center;
    gap: .35rem;
  }
  .nav-lock-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--ivory-deep);
    display: inline-block;
  }

  /* ── HOME ── */
  .home-hero {
    min-height: 88vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 5rem 2rem;
    position: relative;
  }
  .home-hero::before {
    display: none;
  }
  .hero-kicker {
    font-size: .65rem;
    letter-spacing: .28em;
    text-transform: uppercase;
    color: var(--oak);
    margin-bottom: 2rem;
    font-weight: 400;
  }
  .hero-headline {
    font-family: var(--serif);
    font-size: clamp(3.2rem, 8vw, 6.5rem);
    font-weight: 400;
    line-height: 1.05;
    color: var(--ink);
    margin-bottom: 1.75rem;
    position: relative;
  }
  .hero-headline em {
    font-style: normal;
    color: var(--ink);
  }
  .hero-rule {
    width: 60px; height: 1px;
    background: var(--oak-light);
    margin: 0 auto 1.75rem;
  }
  .hero-sub {
    font-size: .95rem;
    color: var(--ink);
    max-width: 380px;
    line-height: 1.8;
    font-weight: 300;
    margin-bottom: 3.5rem;
  }

  /* Countdown */
  .countdown {
    display: flex;
    gap: 4rem;
    margin-bottom: .75rem;
  }
  .cd-unit { text-align: center; }
  .cd-num {
    font-family: var(--serif);
    font-size: 3.2rem;
    font-weight: 400;
    color: var(--ink);
    line-height: 1;
    display: block;
  }
  .cd-label {
    font-size: .6rem;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--ink-lighter);
    margin-top: .35rem;
    display: block;
  }
  .cd-note {
    font-size: .72rem;
    letter-spacing: .1em;
    color: var(--ink-lighter);
    margin-bottom: 3rem;
  }

  /* CTAs */
  .btn-row { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .btn {
    font-family: var(--sans);
    font-size: .65rem;
    font-weight: 400;
    letter-spacing: .18em;
    text-transform: uppercase;
    padding: .85rem 2.2rem;
    cursor: pointer;
    transition: all .25s;
    border: 1px solid;
    display: inline-block;
    text-decoration: none;
  }
  .btn-dark {
    background: var(--ink);
    color: var(--ivory);
    border-color: var(--ink);
  }
  .btn-dark:hover { background: #3d372f; border-color: #3d372f; }
  .btn-ghost {
    background: transparent;
    color: var(--ink);
    border-color: var(--ivory-deep);
  }
  .btn-ghost:hover { border-color: var(--ink); }

  /* About strip */
  .about-strip {
    background: var(--white);
    border-top: 1px solid var(--ivory-deep);
    border-bottom: 1px solid var(--ivory-deep);
    padding: 4rem 3rem;
  }
  .about-inner { max-width: 900px; margin: 0 auto; }
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1px 1fr 1px 1fr;
    gap: 0;
    margin-bottom: 3.5rem;
  }
  .about-divider {
    background: var(--ivory-deep);
    margin: 0 2.5rem;
  }
  .about-item { text-align: center; padding: 1.5rem 1rem; }
  .about-item-label {
    font-size: .6rem;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--oak);
    margin-bottom: .6rem;
  }
  .about-item-value {
    font-family: var(--serif);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--ink);
  }
  .about-note {
    text-align: center;
    max-width: 520px;
    margin: 0 auto;
    font-size: .88rem;
    color: var(--ink-light);
    line-height: 1.9;
  }
  .about-note-head {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.3rem;
    color: var(--ink);
    margin-bottom: .75rem;
    display: block;
  }

  /* ── REGISTRY ── */
  .reg-wrap { max-width: 780px; margin: 0 auto; padding: 5rem 2rem; }
  .page-header { text-align: center; margin-bottom: 4rem; }
  .page-kicker {
    font-size: .62rem;
    letter-spacing: .25em;
    text-transform: uppercase;
    color: var(--oak);
    margin-bottom: 1rem;
  }
  .page-title {
    font-family: var(--serif);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 400;
    line-height: 1.15;
    margin-bottom: 1rem;
  }
  .page-title em { font-style: italic; color: var(--oak); }
  .page-sub {
    font-size: .85rem;
    color: var(--ink-light);
    max-width: 440px;
    margin: 0 auto;
    line-height: 1.8;
  }
  .reg-affiliate-note {
    background: var(--white);
    border: 1px solid var(--ivory-deep);
    padding: 1.25rem 1.75rem;
    margin-bottom: 3.5rem;
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
  .reg-affiliate-bar {
    width: 2px;
    flex-shrink: 0;
    background: var(--oak-light);
    align-self: stretch;
  }
  .reg-affiliate-text { font-size: .8rem; color: var(--ink-light); line-height: 1.7; }
  .reg-affiliate-text strong { color: var(--ink); font-weight: 400; }

  .reg-category { margin-bottom: 3.5rem; }
  .reg-cat-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .reg-cat-label {
    font-size: .62rem;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--ink-lighter);
    white-space: nowrap;
  }
  .reg-cat-line { flex: 1; height: 1px; background: var(--ivory-deep); }

  .reg-item {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--ivory-dark);
    transition: background .2s;
  }
  .reg-item:last-child { border-bottom: none; }
  .reg-item-info { flex: 1; }
  .reg-item-name {
    font-size: .92rem;
    font-weight: 400;
    color: var(--ink);
    margin-bottom: .2rem;
    letter-spacing: .01em;
  }
  .reg-item-detail { font-size: .78rem; color: var(--ink-lighter); }
  .reg-priority {
    font-size: .58rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    padding: .25rem .7rem;
    border: 1px solid;
    flex-shrink: 0;
  }
  .priority-essential {
    color: var(--oak);
    border-color: var(--oak-light);
    background: #f9f4ec;
  }
  .priority-nice {
    color: var(--ink-lighter);
    border-color: var(--ivory-deep);
  }
  .reg-link {
    font-size: .62rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--ink);
    border: 1px solid var(--ivory-deep);
    padding: .55rem 1.1rem;
    text-decoration: none;
    flex-shrink: 0;
    transition: all .2s;
    white-space: nowrap;
  }
  .reg-link:hover { border-color: var(--ink); background: var(--ink); color: var(--ivory); }

  .reg-footer {
    text-align: center;
    padding-top: 3rem;
    border-top: 1px solid var(--ivory-deep);
    margin-top: 2rem;
  }
  .reg-footer p { font-size: .78rem; color: var(--ink-lighter); margin-bottom: 1.25rem; }

  /* ── LOCK SCREEN ── */
  .lock-screen {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 2rem;
  }
  .lock-card {
    max-width: 400px;
    width: 100%;
    text-align: center;
  }
  .lock-ornament {
    width: 32px; height: 32px;
    border: 1px solid var(--ivory-deep);
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 2rem;
    color: var(--ink-lighter);
    font-size: .85rem;
  }
  .lock-title {
    font-family: var(--serif);
    font-size: 1.9rem;
    font-weight: 400;
    margin-bottom: .5rem;
  }
  .lock-title em { font-style: italic; color: var(--oak); }
  .lock-sub {
    font-size: .82rem;
    color: var(--ink-light);
    margin-bottom: 2.5rem;
    line-height: 1.7;
  }
  .pw-field {
    width: 100%;
    padding: .85rem 1rem;
    background: var(--white);
    border: 1px solid var(--ivory-deep);
    font-family: var(--sans);
    font-size: .85rem;
    font-weight: 300;
    letter-spacing: .12em;
    text-align: center;
    color: var(--ink);
    outline: none;
    margin-bottom: .75rem;
    transition: border-color .2s;
  }
  .pw-field:focus { border-color: var(--oak-light); }
  .pw-error {
    font-size: .72rem;
    color: #a0522d;
    letter-spacing: .04em;
    min-height: 1.1rem;
    margin-bottom: .5rem;
  }
  .lock-hint {
    font-size: .68rem;
    color: var(--ink-lighter);
    letter-spacing: .08em;
    margin-top: 1.25rem;
  }

  /* ── PHOTOS ── */
  .photos-wrap { max-width: 900px; margin: 0 auto; padding: 5rem 2rem; }
  .photo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4px;
    margin-top: 3rem;
  }
  .photo-tile {
    aspect-ratio: 1;
    background: var(--ivory-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: opacity .2s;
    position: relative;
    overflow: hidden;
  }
  .photo-tile:hover { opacity: .85; }
  .photo-tile img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .photo-tile-placeholder {
    text-align: center;
    color: var(--ivory-deep);
  }
  .photo-tile-placeholder svg { display: block; margin: 0 auto .5rem; }
  .photo-tile-placeholder span {
    font-size: .6rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--ink-lighter);
  }
  .photo-tile-label {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: linear-gradient(transparent, rgba(42,38,32,.5));
    padding: 1.5rem .75rem .6rem;
    font-size: .6rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: rgba(255,255,255,.8);
  }
  .photo-upload-note {
    text-align: center;
    margin-top: 2rem;
    font-size: .75rem;
    color: var(--ink-lighter);
    line-height: 1.7;
  }

  /* ── UPDATES ── */
  .updates-wrap { max-width: 640px; margin: 0 auto; padding: 5rem 2rem; }
  .update-post { margin-bottom: 4.5rem; }
  .update-post:last-child { margin-bottom: 0; }
  .update-meta {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 1.25rem;
  }
  .update-date {
    font-size: .62rem;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--oak);
  }
  .update-meta-line { flex: 1; height: 1px; background: var(--ivory-deep); }
  .update-title {
    font-family: var(--serif);
    font-size: 1.6rem;
    font-weight: 400;
    line-height: 1.25;
    margin-bottom: 1rem;
    color: var(--ink);
  }
  .update-title em { font-style: italic; color: var(--oak); }
  .update-body {
    font-size: .88rem;
    color: var(--ink-light);
    line-height: 2;
    font-weight: 300;
    margin-bottom: 1.25rem;
  }
  .update-img {
    width: 100%;
    background: var(--ivory-dark);
    height: 260px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 1.25rem 0;
    font-size: .65rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--ink-lighter);
  }

  /* ── FOOTER ── */
  footer {
    border-top: 1px solid var(--ivory-deep);
    padding: 2.5rem 3rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .footer-wordmark {
    font-family: var(--serif);
    font-size: .85rem;
    font-style: italic;
    color: var(--ink-lighter);
  }
  .footer-note { font-size: .65rem; letter-spacing: .1em; color: var(--ink-lighter); }

  /* ── RESPONSIVE ── */
  @media (max-width: 700px) {
    nav { padding: 1.1rem 1.25rem; }
    .nav-links { gap: 1.25rem; }
    .countdown { gap: 2rem; }
    .about-grid { grid-template-columns: 1fr; }
    .about-divider { display: none; }
    .photo-grid { grid-template-columns: repeat(2, 1fr); }
    footer { flex-direction: column; gap: .75rem; text-align: center; }
    .reg-wrap, .photos-wrap, .updates-wrap { padding: 3rem 1.25rem; }
  }
</style>
</head>
